NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Vercel production: use /api proxy (see .env.production.example and VERCEL.md)
# BACKEND_URL is set on Vercel only (not NEXT_PUBLIC)
# NEXT_PUBLIC_API_PORT=4000
# Google Maps JavaScript API key (Maps JavaScript API enabled)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
