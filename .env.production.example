# === Vercel Environment Variables (Production) ===
# Vercel Dashboard → Project → Settings → Environment Variables

# Backend server URL (server-side only — Vercel rewrites /api → this URL)
BACKEND_URL=http://103.179.45.111:4000

# MUST be /api on Vercel (do NOT use http:// backend URL — Mixed Content blocked)
NEXT_PUBLIC_API_URL=/api

# Your Vercel frontend domain
NEXT_PUBLIC_FRONTEND_URL=https://word-of-mouth-marketing-easier-ai.vercel.app

# Google Maps API key (add Vercel domain to HTTP referrer restrictions)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
