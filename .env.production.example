# === Vercel Environment Variables (Production) ===
# Set these in Vercel Dashboard → Project → Settings → Environment Variables

# Backend server URL (server-side only — used for /api and /uploads rewrites)
# Example: http://103.179.45.111:4000  or  https://api.your-domain.com
BACKEND_URL=http://103.179.45.111:4000

# Client API path — use /api to proxy through Vercel (recommended for HTTP backends)
NEXT_PUBLIC_API_URL=/api

# Public frontend URL (for OAuth return links; use your Vercel domain or custom domain)
NEXT_PUBLIC_FRONTEND_URL=https://your-project.vercel.app

# Google Maps JavaScript API key (restrict HTTP referrers to your Vercel domain)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCjQvXHvG89naTtATFObUlJZhJgEFCccdg
